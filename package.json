{
  "name": "flag-status-monitor",
  "version": "3.0.0",
  "description": "A real-time, installable PWA that tracks the U.S. flag's official staff position with live updates, history, and accessible design.",
  "main": "src/js/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,css}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"*.{js,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node generate-icons.mjs",
    "serve:mock": "python3 server.py"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "flag",
    "flag-status",
    "half-staff",
    "pwa",
    "government",
    "vite",
    "vanilla-js"
  ],
  "author": "Jacob Booth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacob-booth/flag-status-monitor.git"
  },
  "homepage": "https://jacob-booth.github.io/flag-status-monitor"
}
